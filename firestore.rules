rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /contentLibrary/{contentId} {
      allow read: if request.auth != null
        && resource.data.status == "published";

      allow create, update, delete: if false;
    }

    match /users/{userId} {
      allow read: if request.auth != null
        && request.auth.uid == userId;

      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.classLevel is string
        && request.resource.data.classLevel in ["5", "6", "7", "9", "10"]
        && request.resource.data.board == "CBSE";

      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.classLevel == resource.data.classLevel
        && request.resource.data.board == resource.data.board;

      allow delete: if false;

      match /topicProgress/{progressId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      match /revisionProgress/{revisionId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      match /testResults/{testId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      match /chatSessions/{sessionId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      match /doubts/{doubtId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      match /notes/{noteId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      match /activityLogs/{logId} {
        allow read, create: if request.auth != null
          && request.auth.uid == userId;

        allow update, delete: if false;
      }

      match /reports/{reportId} {
        allow read, create: if request.auth != null
          && request.auth.uid == userId;

        allow update, delete: if false;
      }

      match /usageDays/{dayId} {
        allow read, create, update: if request.auth != null
          && request.auth.uid == userId;

        allow delete: if false;
      }

      match /dailyGoals/{dayId} {
        allow read, create, update: if request.auth != null
          && request.auth.uid == userId;

        allow delete: if false;
      }
    }
  }
}
